# Backend database and CORS configuration
DATABASE_URL=sqlite:///storage/database/walletmind.db
ALLOWED_ORIGINS=http://localhost:5173

# Backend AI configuration
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
TEMPERATURE=0.2
MAX_OUTPUT_TOKENS=2048

# Frontend build/runtime metadata (for frontend/.env)
VITE_API_BASE_URL=http://127.0.0.1:8000
VITE_APP_VERSION=0.1.0
VITE_BUILD_DATE=
VITE_GIT_COMMIT=