# ==========================================================
# WalletMind .gitignore
# ==========================================================

# ----------------------------
# Python
# ----------------------------
__pycache__/
*.py[cod]
*$py.class
*.pyd
*.so

# Virtual Environments
.venv/
venv/
env/
ENV/

# Python caches
.pytest_cache/
.mypy_cache/
.pytype/
.pyre/
.ruff_cache/
.hypothesis/
.coverage
.coverage.*
htmlcov/

# Build
build/
dist/
*.egg-info/
.eggs/
*.egg
pip-wheel-metadata/

# Jupyter
.ipynb_checkpoints/

# ----------------------------
# Environment
# ----------------------------
.env
.env.*
!.env.example

# ----------------------------
# IDE
# ----------------------------
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json
!.vscode/launch.json

.idea/
.history/

# ----------------------------
# OS
# ----------------------------
.DS_Store
Thumbs.db
Desktop.ini

# ----------------------------
# Logs
# ----------------------------
logs/*
!logs/.gitkeep

*.log

# ----------------------------
# Runtime Storage
# ----------------------------
storage/cache/*
!storage/cache/.gitkeep

storage/uploads/*
!storage/uploads/.gitkeep

storage/memory/*
!storage/memory/.gitkeep

storage/reports/*
!storage/reports/.gitkeep

storage/sessions/*
!storage/sessions/.gitkeep

storage/database/*
!storage/database/.gitkeep

# SQLite
*.db
*.sqlite
*.sqlite3

# ----------------------------
# Outputs
# ----------------------------
outputs/*
!outputs/.gitkeep

# ----------------------------
# Notebook exports
# ----------------------------
notebook/*.html
notebook/*.pdf

# ----------------------------
# Assets
# ----------------------------
assets/diagrams/generated/

# ----------------------------
# Private sample data
# ----------------------------
sample_data/private/*
!sample_data/private/.gitkeep

# ==========================================================
# Frontend (React / Vite)
# ==========================================================

frontend/node_modules/
frontend/dist/
frontend/build/
frontend/.vite/
frontend/.cache/
frontend/coverage/

frontend/npm-debug.log*
frontend/yarn-debug.log*
frontend/yarn-error.log*
frontend/pnpm-debug.log*

# ==========================================================
# Backend
# ==========================================================

backend/__pycache__/
backend/.pytest_cache/

# ==========================================================
# Testing
# ==========================================================

.pytest_cache/
coverage/
coverage.xml

# ==========================================================
# Temporary
# ==========================================================

tmp/
temp/
*.tmp
*.bak

# ==========================================================
# Package Managers
# ==========================================================

package-lock.json
yarn.lock
pnpm-lock.yaml

# Keep if using uv
# uv.lock

# ==========================================================
# Misc
# ==========================================================

.marimo/
.streamlit/secrets.toml

# Runtime data
storage/database/*
!storage/database/.gitkeep
storage/database/walletmind.db

storage/uploads/*
!storage/uploads/.gitkeep

storage/cache/*
!storage/cache/.gitkeep

storage/memory/*
!storage/memory/.gitkeep

storage/reports/*
!storage/reports/.gitkeep

storage/sessions/*
!storage/sessions/.gitkeep